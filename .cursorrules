## TypeScript/Vue 代码风格

### 1. 严格类型

```typescript
// ✅ 使用具体类型
interface FoodRecord {
  id: number;
  name: string;
  calories: number;
  mealType: MealType;
  recordedAt: string;
}

type MealType = "早餐" | "午餐" | "晚餐" | "加餐";

// ❌ 避免使用 any
function handleData(data: any) { }
```

### 2. 组件命名

```vue
<!-- 单文件组件：PascalCase -->
<template>
  <div class="food-dashboard">
    <h2>{{ totalCalories }}</h2>
  </div>
</template>

<script setup lang="ts">
import { computed } from 'vue';

interface FoodDashboardProps {
  records: FoodRecord[];
}

const props = defineProps<FoodDashboardProps>();

const totalCalories = computed(() => 
  props.records.reduce((sum, r) => sum + r.calories, 0)
);
</script>
```

### 3. Composables 规范

```typescript
// 自定义 Composables 以 use 开头
// src/composables/useFoodRecords.ts
import { ref, computed } from 'vue';

export const useFoodRecords = (userId: number) => {
  const records = ref<FoodRecord[]>([]);
  const loading = ref(false);
  
  const fetchRecords = async (date: string) => {
    loading.value = true;
    try {
      const data = await foodApi.getRecords(userId, date);
      records.value = data;
    } finally {
      loading.value = false;
    }
  };
  
  const totalCalories = computed(() => 
    records.value.reduce((sum, r) => sum + r.calories, 0)
  );
  
  return { 
    records, 
    loading, 
    fetchRecords,
    totalCalories
  };
};
```

### 4. 组件 Props 类型

```typescript
// 使用 defineProps 进行类型定义
interface FoodListProps {
  records: FoodRecord[];
}

const props = defineProps<FoodListProps>();

// 使用 defineEmits 定义事件
const emit = defineEmits<{
  delete: [id: number];
  edit: [record: FoodRecord];
}>();
```

